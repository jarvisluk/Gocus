{
  "name": "gocus",
  "version": "0.1.1",
  "private": true,
  "description": "A compact side-floating Git tracking utility for desktop.",
  "repository": {
    "type": "git",
    "url": "https://github.com/jarvisluk/gocus.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:web": "vite --host 127.0.0.1 --port 43871",
    "audit": "npm run audit:dependencies && npm run audit:secrets",
    "audit:dependencies": "npm audit",
    "audit:secrets": "node scripts/check-secrets.cjs",
    "lint": "npm run lint:design && npm run lint:hygiene && npm run lint:node && npm run lint:shell",
    "lint:design": "stylelint \"src/**/*.css\"",
    "lint:hygiene": "node scripts/check-source-hygiene.cjs",
    "lint:node": "node scripts/check-node-syntax.cjs",
    "lint:shell": "node scripts/check-shell-syntax.cjs",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "node scripts/test-unit.cjs",
    "test:ui": "node scripts/smoke-ui.cjs",
    "verify": "npm run audit && npm run lint && npm test && npm run build",
    "build": "tsc --noEmit && vite build",
    "package:mac": "./scripts/package-macos.sh",
    "package:mac:release": "./scripts/package-macos.sh --no-install",
    "preview": "vite preview --host 127.0.0.1",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^39.2.7",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "playwright": "^1.60.0",
    "stylelint": "^17.12.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.3"
  }
}
